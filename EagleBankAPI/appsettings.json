{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "EagleBankAPI": "Information",
      "EagleBankAPI.Core.Services": "Information"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss ",
        "IncludeScopes": true
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=EagleBankDB;Trusted_Connection=true;MultipleActiveResultSets=true",
    "InMemoryConnection": "InMemory"
  },
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_SECURE_KEY_FROM_ENVIRONMENT_OR_USER_SECRETS",
    "Issuer": "EagleBankAPI",
    "Audience": "EagleBankAPIUsers",
    "ExpiryMinutes": "60"
  },
  "UseInMemoryDatabase": true
}
